# MongoDB
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=fake_news_detector
SOURCE_DB=new
RESULT_DB=fake_news_detector
ARTICLES_COLLECTION=articles
CONTENTS_COLLECTION=contents
URLS_COLLECTION=urls
URLS_COLLECTION_NAME=urls
ANALYSIS_COLLECTION=url_analyses
ANALYSIS_COLLECTION_NAME=url_analyses
UNKNOWN_URLS_COLLECTION_NAME=unknown_urls

# Flask API
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_DEBUG=true

# Model / inference
MODEL_PATH=testing_mbert
PIPELINE_LOCK_FILE=/tmp/fake_news_pipeline.lock
LOCK_TIMEOUT_SEC=1800

# Crawler / Firecrawl
FIRECRAWL_BASE=http://localhost:3002
FIRECRAWL_API_KEY=
FIRECRAWL_WAIT_MS=6000
FIRECRAWL_ONLY_MAIN_CONTENT=false
FIRECRAWL_DEBUG=false

CRAWLER_MONGO_URI=mongodb://localhost:27017/
CRAWLER_DB_NAME=new
CRAWLER_WORKER_PY=crawler/fccna_worker.py
CRAWLER_JOBS_DIR=crawler/jobs
CRAWLER_EXPORT_DIR=crawler/exports
ENABLE_CRAWLER_TRIGGER=true

TARGET_ARTICLES=500
MAX_FRONTIER_SIZE=50000
MAX_VISITED_URLS=200000
SEED_CATEGORY_PAGES=3
SEED_LIMIT_PER_PAGE=40
BULK_SIZE=100
MIN_CONTENT_LEN=200
MAX_PROXY_RETRIES=3
CRAWL_DELAY_MIN=1.5
CRAWL_DELAY_MAX=3.0
MAX_ARTICLES_PER_DOMAIN=5
SAME_DOMAIN_EXTRA_DELAY_MIN=2.0
SAME_DOMAIN_EXTRA_DELAY_MAX=4.0

# Optional comma-separated settings
PROXY_POOL=
CRAWL_DOMAINS=
WHITELIST_EXTRA_DOMAINS=
BLACKLIST_EXTRA_DOMAINS=
